// taller Contraseñas
import java.util.Scanner;

class Main {

    int n=0, cf=0, cm=0, cd=0;
    String[] passwords;
    Scanner leer;

    public void cantidad_password(){
        leer=new Scanner(System.in);
        System.out.print("Ingrese el numero de contraseñas: ");
        n=leer.nextInt();
        leer.nextLine();
        System.out.println("La contraseña debe tener al menos 8 caracteres, una letra mayuscula, una letra minuscula y un numero");
    }
    public void pedir_password(){
        passwords=new String[n];
        for(int i=0; i<n; i++){
            System.out.print("Ingrese la contraseña "+(i+1)+": ");
            passwords[i]=leer.nextLine();
        }
    }

    public void criterios_password(){

        for(int c=0;c<n;c++){

            int crit=0;
            int mayus=0, minus=0, num=0;

            if(passwords[c].length()>=8){
                crit++;
            }

            for(int i=0; i<passwords[c].length();i++){

                char m=passwords[c].charAt(i);

                if(Character.isUpperCase(m)){
                    mayus=1;
                }

                if(Character.isLowerCase(m)){
                    minus=1;
                }

                if(Character.isDigit(m)){
                    num=1;
                }
            }
            crit=crit+mayus+minus+num;
            if(crit==4){
                cf++;
            }
            else if(crit==3){
                cm++;
            }
            else if(crit==2){
                cd++;
            }
        }
    }

    public void imprimir_criterios(){
        System.out.println("Contraseñas fuertes: "+cf);
        System.out.println("Contraseñas medias: "+cm);
        System.out.println("Contraseñas debiles: "+cd);
    }

    public static void main(String[] args){

        Main pass=new Main();

        pass.cantidad_password();
        pass.pedir_password();
        pass.criterios_password();
        pass.imprimir_criterios();
    }
}
