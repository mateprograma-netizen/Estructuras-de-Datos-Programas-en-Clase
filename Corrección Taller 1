// Correccion Taller Contraseñas
import java.util.Scanner;
class Main {
    int n=0, cf=0, cm=0, cd=0;
    String passwords;
    Scanner leer;
    public void cantidad_password(){
        leer=new Scanner(System.in);
        System.out.print("Ingrese el numero de contraseñas: ");
        n=leer.nextInt();
        leer.nextLine();
        System.out.println("La contraseña debe tener al menos 8 caracteres, una letra mayuscula, una letra minuscula y un numero");
    }
    public void criterios_password(){
        for(int i=0; i<n; i++) {
            System.out.println("Ingrese la contraseña "+(i+1)+": ");
            passwords=leer.nextLine();
            int critc= 0;
            if (passwords.length() >= 8){
                critc++;
            }
            int mayuscula=0;
            int minuscula=0;
            int numero=0;
            for(int j=0; j<passwords.length(); j++) {
                char m=passwords.charAt(j);
                if (Character.isUpperCase(m)) {
                    mayuscula++;
                }else if (Character.isLowerCase(m)) {
                    minuscula++;
                }else if (Character.isDigit(m)) {
                    numero++;
                }
            }
            if(mayuscula>0){
                critc++;
            }
            if(minuscula>0){
                critc++;
            }
            if(numero>0){
                critc++;
            }
            if(critc==4){
                System.out.println("Contraseña Fuerte");
                cf++;
            }else if(critc==3){
                System.out.println("Contraseña Media");
                cm++;
            }else{
                System.out.println("Contraseña Debil");
                cd++;
            }
        }
    }
    public void imprimir_criterios(){
        System.out.println(" ");
        System.out.println("Contraseñas fuertes: "+cf);
        System.out.println("Contraseñas medias: "+cm);
        System.out.println("Contraseñas debiles: "+cd);
    }
    public static void main(String[] args){
        Main cts=new Main();
        cts.cantidad_password();
        cts.criterios_password();
        cts.imprimir_criterios();
    }
}

